{
  "buildCommand": "pnpm run typecheck:deploy && pnpm --filter @workspace/broker-tenant-onboarding run build && pnpm --filter @workspace/tenant-document-upload run build && pnpm --filter @workspace/trustkeyper run build",
  "outputDirectory": "artifacts/trustkeyper/dist",
  "installCommand": "pnpm install",
  "functions": {
    "api/sync.ts": {
      "maxDuration": 30
    },
    "api/feedback.ts": {
      "maxDuration": 30
    },
    "api/broker-tenant-onboard.ts": {
      "maxDuration": 30
    },
    "api/tenant-document-upload.ts": {
      "maxDuration": 30
    },
    "api/payments-onboard.ts": {
      "maxDuration": 30
    },
    "api/payments-onboard-complete.ts": {
      "maxDuration": 30
    },
    "api/razorpay-webhook.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/sync/(.*)",
      "destination": "/api/sync?syncPath=$1"
    },
    {
      "source": "/api/invitations/(.*)",
      "destination": "/api/invitations?invitePath=$1"
    },
    {
      "source": "/api/share/property/(.*)",
      "destination": "/api/share-property?sharePath=property/$1"
    },
    {
      "source": "/api/broker-tenant-onboard/(.*)",
      "destination": "/api/broker-tenant-onboard?onboardPath=$1"
    },
    {
      "source": "/api/tenant-document-upload/(.*)",
      "destination": "/api/tenant-document-upload?uploadPath=$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
