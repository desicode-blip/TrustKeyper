{
  "buildCommand": "pnpm run typecheck:deploy && pnpm --filter @workspace/trustkeyper run build",
  "outputDirectory": "artifacts/trustkeyper/dist",
  "installCommand": "pnpm install",
  "functions": {
    "api/sync.ts": {
      "maxDuration": 30
    },
    "api/invitations.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/sync/(.*)",
      "destination": "/api/sync?syncPath=$1"
    },
    {
      "source": "/api/invitations/(.*)",
      "destination": "/api/invitations?invitePath=$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
