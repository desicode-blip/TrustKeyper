{
  "buildCommand": "pnpm --filter @workspace/trustkeyper run build",
  "outputDirectory": "artifacts/trustkeyper/dist",
  "installCommand": "pnpm install",
  "rewrites": [
    {
      "source": "/api/sync/(.*)",
      "destination": "/api/sync?syncPath=$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
