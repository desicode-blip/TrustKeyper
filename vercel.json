{
  "buildCommand": "pnpm run typecheck:deploy && pnpm --filter @workspace/broker-tenant-onboarding run build && pnpm --filter @workspace/tenant-document-upload run build && pnpm --filter @workspace/tenant-workflow run build && pnpm --filter @workspace/api-server run build && node scripts/build-vercel-output.mjs",
  "outputDirectory": "dist-vercel",
  "installCommand": "pnpm install",
  "functions": {
    "api/sync.ts": {
      "maxDuration": 30
    },
    "api/feedback.ts": {
      "maxDuration": 30
    },
    "api/broker-tenant-onboard.ts": {
      "maxDuration": 30
    },
    "api/tenant-document-upload.ts": {
      "maxDuration": 30
    },
    "api/payments-onboard.ts": {
      "maxDuration": 30
    },
    "api/payments-onboard-complete.ts": {
      "maxDuration": 30
    },
    "api/razorpay-webhook.ts": {
      "maxDuration": 30
    },
    "api/payments-create-order.ts": {
      "maxDuration": 30
    },
    "api/payments-create-escrow-order.ts": {
      "maxDuration": 30
    },
    "api/payments-release-escrow.ts": {
      "maxDuration": 30
    },
    "api/tenant-workflow.ts": {
      "maxDuration": 30
    },
    "api/upload-property-image.ts": {
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/owner",
      "destination": "/_app/owner/dashboard",
      "permanent": false
    },
    {
      "source": "/owner/:path*",
      "destination": "/_app/owner/:path*",
      "permanent": false
    },
    {
      "source": "/broker",
      "destination": "/_app/broker/dashboard",
      "permanent": false
    },
    {
      "source": "/broker/:path*",
      "destination": "/_app/broker/:path*",
      "permanent": false
    },
    {
      "source": "/tenant",
      "destination": "/_app/tenant/dashboard",
      "permanent": false
    },
    {
      "source": "/tenant/:path*",
      "destination": "/_app/tenant/:path*",
      "permanent": false
    },
    {
      "source": "/admin/:path*",
      "destination": "/_app/admin/:path*",
      "permanent": false
    },
    {
      "source": "/share/:path*",
      "destination": "/_app/share/:path*",
      "permanent": false
    },
    {
      "source": "/onboard/:path*",
      "destination": "/_app/onboard/:path*",
      "permanent": false
    },
    {
      "source": "/upload/:path*",
      "destination": "/_app/upload/:path*",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/sync/(.*)",
      "destination": "/api/sync?syncPath=$1"
    },
    {
      "source": "/api/invitations/(.*)",
      "destination": "/api/invitations?invitePath=$1"
    },
    {
      "source": "/api/share/property/(.*)",
      "destination": "/api/share-property?sharePath=property/$1"
    },
    {
      "source": "/api/broker-tenant-onboard/(.*)",
      "destination": "/api/broker-tenant-onboard?onboardPath=$1"
    },
    {
      "source": "/api/tenant-document-upload/(.*)",
      "destination": "/api/tenant-document-upload?uploadPath=$1"
    },
    {
      "source": "/api/tenant-workflow/(.*)",
      "destination": "/api/tenant-workflow?workflowPath=$1"
    },
    {
      "source": "/_app/:path*",
      "destination": "/_app/index.html"
    },
    {
      "source": "/((?!api/|_app/).*)",
      "destination": "/index.html"
    }
  ]
}
