auto-install-peers=false
strict-peer-dependencies=false

# One physical copy of Drizzle for all workspace packages (avoids TS "separate declarations" errors on Vercel).
public-hoist-pattern[]=drizzle-orm
public-hoist-pattern[]=drizzle-kit

# Expo / Metro resolution for apps/mobile (@expo/cli needs transitive metro packages at root)
public-hoist-pattern[]=*metro*
public-hoist-pattern[]=@expo/*
public-hoist-pattern[]=react-native*
public-hoist-pattern[]=expo-*
