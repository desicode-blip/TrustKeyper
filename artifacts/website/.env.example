# Marketing website — copy to .env.local for local development.
# Vite loadEnv reads these at dev/build time (see vite.config.ts).

# API base URL including /api (dev: main app server). Omit in production to use same-origin /api
# when proxied, or set to https://app.trustkeyper.com/api for cross-origin calls.
# VITE_API_URL=http://localhost:8080/api

# Supabase (marketing auth modal)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Set to 1 only on the real production domain deploy (trustkeyper.com build).
# Read from .env.local / .env.production.local via Vite loadEnv — omitted from dist/index.html when unset.
# VITE_ENABLE_ANALYTICS=1
