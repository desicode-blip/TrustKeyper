# Copy to `.env`, then run: pnpm run dev:local
#
# Embedded local DB (default — no Docker): stores data in .data/pglite
DATABASE_URL=local
PGLITE_DATA_DIR=.data/pglite
#
# Docker Postgres instead: pnpm run db:up  then set:
# DATABASE_URL=postgresql://trustkeyper:trustkeyper@localhost:5432/trustkeyper_dev

# Server — API listens on PORT / API_PORT; Vite uses WEB_PORT (do not share one port)
API_PORT=8080
WEB_PORT=5173
PORT=8080

# Production (Vercel): Supabase Postgres connection string; BLOB_STORE_ID from connected Blob store (OIDC)
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# BLOB_STORE_ID=

# Prototype / Vercel trial (in-memory DB + demo accounts — resets on cold starts)
# USE_MOCK_DB=1
# On Vercel, mock mode auto-enables when DATABASE_URL is not set (and no legacy BLOB_READ_WRITE_TOKEN).

# Disposable local test sandbox (isolated PGLite — delete anytime):
#   pnpm run test:db:create
#   pnpm run test:db:dev
#   pnpm run test:db:destroy

# Frontend Supabase Auth (use artifacts/trustkeyper/.env.local for Vite dev)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-side JWT verification for /api/sync (Vercel + local Express)
# Use the same project URL and anon key as above — never the service role key.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SYNC_AUTH_DISABLED=1   # optional: skip sync JWT checks (local mock only)

# Admin portal allowlist (comma-separated 10-digit phone numbers)
# ADMIN_PHONES=9999999999,8888888888
# VITE_ADMIN_PHONES=9999999999,8888888888

# Email (Resend) — feedback notifications and managed-interest form
# RESEND_API_KEY=re_xxxxxxxx
# FEEDBACK_FROM_EMAIL=TrustKeyper Feedback <feedback@trustkeyper.com>
# FEEDBACK_NOTIFY_EMAIL=info@trustkeyper.com

# AI feedback analysis (Google Gemini)
# GEMINI_API_KEY=your-gemini-api-key

# Razorpay Route (server-side only — never expose in VITE_* vars)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# Tenant invitations — days before an invite expires (default: 7)
# INVITE_EXPIRY_DAYS=7

# Frontend — optional overrides (production uses same-origin /api by default)
# VITE_API_URL=http://localhost:8080/api
# WEB_PORT=5173
# VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Marketing website (artifacts/website) — staging example:
# WEBSITE_PORT=5174
# VITE_API_URL=https://staging.app.trustkeyper.com/api
# VITE_APP_URL=https://staging.app.trustkeyper.com

# App SPA (artifacts/trustkeyper) — redirect auth entry to marketing site when set:
# VITE_MARKETING_URL=https://staging.trustkeyper.com
