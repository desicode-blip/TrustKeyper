{
  "expo": {
    "name": "TrustKeyper",
    "slug": "trustkeyper-mobile",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "trustkeyper",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.trustkeyper.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.trustkeyper.mobile"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
