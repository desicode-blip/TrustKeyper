# Copy to .env and fill from the same Supabase project as the web app.
# Auth uses Supabase Phone OTP (Twilio Verify is configured in the Supabase dashboard).

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Vercel API base including /api (e.g. https://app.trustkeyper.com/api)
EXPO_PUBLIC_API_URL=
